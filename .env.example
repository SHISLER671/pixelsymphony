# Server-only Venice key (preferred — never expose to browser)
VENICE_API_KEY=

# Optional legacy names also accepted by /api/translate
# VENICE_INFERENCE_KEY=
# NEXT_PUBLIC_VENICE_API_KEY=

# WalletConnect / RainbowKit project id (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Public app URL for WalletConnect metadata
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional CORS-friendly Ethereum mainnet RPC
# NEXT_PUBLIC_RPC_URL=https://ethereum.publicnode.com
