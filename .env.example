# Server-only Venice (never commit real keys)
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=zai-org-glm-5-2

# Optional legacy names also accepted by the client
# VENICE_INFERENCE_KEY=

# WalletConnect / RainbowKit project id (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Public app URL for WalletConnect metadata
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional CORS-friendly Ethereum mainnet RPC
# NEXT_PUBLIC_RPC_URL=https://ethereum.publicnode.com
